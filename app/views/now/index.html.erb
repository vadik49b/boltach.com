<% content_for :head do %>
  <meta name="description" content="Software engineer — frontend, design systems, developer experience.">
<% end %>

<div data-controller="theme" class="min-h-screen flex flex-col">
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:px-3 focus:py-2 focus:bg-white focus:text-black focus:rounded">Skip to main content</a>
  <header class="border-b border-dashed text-[12px]" style="border-color: var(--rule);">
    <div class="max-w-3xl mx-auto px-6 py-3 flex flex-wrap items-center justify-between gap-y-2">
      <span>
        London, UK
      </span>
      <button
        type="button"
        data-theme-target="darkToggle"
        data-action="theme#toggleDark"
        aria-pressed="false"
        aria-label="Toggle dark mode"
        class="hover:underline underline-offset-4 cursor-pointer"
      ><span data-theme-target="darkLabel">☾ dark</span></button>
    </div>
  </header>

  <main id="main" class="flex-1">
    <div class="max-w-3xl mx-auto px-6 py-12 md:py-16">

      <section class="grid grid-cols-1 md:grid-cols-[128px_1fr] gap-x-8 gap-y-6 items-start">
        <picture>
          <source srcset="/avatar_logo.avif" type="image/avif">
          <img
            class="w-32 h-32 rounded-xl"
            width="128"
            height="128"
            decoding="async"
            src="/avatar_logo.jpeg"
            alt="Vadim Boltach"
          >
        </picture>

        <div class="space-y-4">
          <h1 class="text-3xl md:text-4xl font-medium rgb-fringe">
            Vadim Boltach
          </h1>
          <p class="leading-relaxed text-base md:text-lg">
            Hey 👋. I&apos;m a software engineer specializing in web applications, design
            systems, and frontend tooling. Love minimalist design and thoughtful UX.
            Trying to make web <s style="color: var(--muted);">sites</s> faster and more
            accessible.
          </p>
          <nav class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm pt-2" aria-label="Contact">
            <a href="mailto:vadim@boltach.com" class="hover:underline underline-offset-4">vadim@boltach.com</a>
            <span aria-hidden="true" style="color: var(--muted);">·</span>
            <a href="https://github.com/vadik49b" class="hover:underline underline-offset-4">github</a>
            <span aria-hidden="true" style="color: var(--muted);">·</span>
            <a href="https://www.linkedin.com/in/vadik49b/" class="hover:underline underline-offset-4">linkedin</a>
          </nav>
        </div>
      </section>

      <section class="mt-14">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm" style="color: var(--muted);">// recent jobs</h2>
          <a href="/vadim_boltach_cv.pdf" download class="text-[12px] hover:underline underline-offset-4">
            <span aria-hidden="true">↓ </span>download cv (pdf, 120 kb)
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            cards = [
              { name: "Coursera", period: "2022 – 2024", location: "Toronto, Canada",
                desc: "Core contributor to Coursera's design system, developing shared components, leading large-scale codebase migrations, driving accessibility and right-to-left languages support, and rolling out design system adoption across ~100 engineers and designers org-wide." },
              { name: "Thriver", period: "2019 – 2021", location: "Toronto, Canada",
                desc: "Joined as one of the first senior engineers on a rapidly growing team, introducing engineering processes and best practices, improving app performance and reliability, and stabilizing releases through CI/CD, code standards, and a reliable E2E test suite." }
            ]
          %>
          <% cards.each do |c| %>
            <article
              class="border rounded-lg p-5 flex flex-col gap-3"
              style="border-color: var(--rule); background: var(--card);"
            >
              <div class="flex items-start justify-between gap-3 text-sm">
                <span><span aria-hidden="true">┌─ </span><strong class="font-semibold"><%= c[:name] %></strong></span>
                <span class="text-[12px] whitespace-nowrap" style="color: var(--muted);"><%= c[:period] %></span>
              </div>
              <p class="text-sm leading-relaxed"><%= c[:desc] %></p>
              <p class="text-[12px] mt-auto" style="color: var(--muted);"><%= c[:location] %></p>
            </article>
          <% end %>
        </div>
      </section>

      <section class="mt-14">
        <h2 class="text-sm mb-4" style="color: var(--muted);">// open source</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <%
            oss = [
              { name: "anki-connect.rb",
                href: "https://github.com/vadik49b/anki-connect.rb",
                desc: "Ruby client for the AnkiConnect HTTP API — script Anki from Ruby applications to manage decks, notes, and cards." },
              { name: "timesweeper",
                href: "https://github.com/vadik49b/timesweeper",
                desc: "Windows 95 Minesweeper-themed group scheduling app — no login, one shareable link, real-time availability grid, offline-first local data, and Cloudflare Worker + Durable Object sync." }
            ]
          %>
          <% oss.each do |o| %>
            <a
              href="<%= o[:href] %>"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="<%= o[:name] %> on GitHub (opens in new tab)"
              class="group border rounded-lg p-5 flex flex-col gap-3"
              style="border-color: var(--rule); background: var(--card);"
            >
              <div class="text-sm">
                <span><span aria-hidden="true">┌─ </span><strong class="font-semibold"><%= o[:name] %></strong></span>
              </div>
              <p class="text-sm leading-relaxed" style="color: var(--ink);"><%= o[:desc] %></p>
              <p class="text-[12px] mt-auto group-hover:underline underline-offset-4" style="color: var(--muted);"><%= o[:href].sub(%r{^https?://}, "") %></p>
            </a>
          <% end %>
        </div>
      </section>
    </div>
  </main>

  <footer class="border-t border-dashed text-[12px]" style="border-color: var(--rule);">
    <div class="max-w-3xl mx-auto px-6 py-3 flex items-center justify-between">
      <span style="color: var(--muted);">
        © <%= Time.current.year %> Vadim Boltach
      </span>
      <% unless authenticated? %>
        <%= link_to login_path, aria: { label: "Sign in" }, class: "inline-flex items-center justify-center opacity-60 hover:opacity-100 transition-opacity" do %>
          <svg width="12" height="14" viewBox="0 0 12 14" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true" class="translate-y-px">
            <rect x="1" y="6" width="10" height="7" rx="1"/>
            <path d="M3 6 V4 a3 3 0 0 1 6 0 V6"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  </footer>
</div>
